# ===============================
# Database (matches docker-compose.yml's `postgres` service)
# ===============================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_agent_playstore
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_agent_playstore

# ===============================
# Redis (rate limiting, token revocation)
# ===============================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ===============================
# Token / Security
# ===============================
# Generate your own: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-generate-a-real-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===============================
# FastAPI / App
# ===============================
API_V1_PREFIX=/api/v1
PROJECT_NAME=AgentHub
DEBUG=True
BACKEND_CORS_ORIGINS=http://localhost:3000

# ===============================
# LLM (Gemini) — https://aistudio.google.com/apikey for a free-tier key
# ===============================
LLM_API_KEY=your-gemini-api-key
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/models
LLM_MODEL=gemini-2.5-flash



